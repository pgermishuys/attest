{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@weaveio/opencode_attest",
  "version": "0.1.0",
  "description": "OpenCode TUI plugin that gates commits behind a comprehension interview",
  "author": "pgermishuys",
  "license": "MIT",
  "homepage": "https://github.com/pgermishuys/attest",
  "repository": {
    "type": "git",
    "url": "https://github.com/pgermishuys/attest.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "keywords": [
    "opencode",
    "plugin",
    "attest",
    "comprehension-gate",
    "weave"
  ],
  "scripts": {
    "build": "bun run script/build.ts && tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/ test/",
    "test:unit": "bun test src/",
    "test:integration": "bun test test/integration/",
    "test:e2e": "bun test test/e2e/",
    "evals": "bun run evals/run-evals.ts"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.4.6",
    "@opencode-ai/sdk": "1.4.6"
  },
  "devDependencies": {
    "@types/bun": "^1.2.18",
    "@types/node": "^22.15.3",
    "bun-types": "^1.3.11",
    "typescript": "^5.8.3"
  }
}
